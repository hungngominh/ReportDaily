# Neon Postgres connection string
# Lấy từ: https://console.neon.tech → Project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT secret để ký session cookie (tạo ngẫu nhiên)
# Windows: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_jwt_secret_here

# Cron secret để bảo vệ endpoint /api/cron/check
# Vercel tự động truyền giá trị này khi gọi cron
CRON_SECRET=your_random_cron_secret_here
